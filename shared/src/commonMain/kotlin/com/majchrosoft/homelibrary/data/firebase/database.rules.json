{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "items": {
          ".indexOn": ["item/title", "item/author", "item/type", "item/bookcase"],
          "$itemId": {
            ".validate": "newData.hasChild('item') && newData.child('item').hasChild('title')"
          }
        },
        "bookcases": {
          ".indexOn": ["name"]
        }
      }
    },
    "catalog": {
      "items": {
        ".read": "auth != null",
        ".indexOn": ["item/title", "item/type"],
        ".write": false
      }
    }
  }
}
