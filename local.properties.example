# Copy this file to `local.properties` and fill in. `local.properties` is gitignored.
sdk.dir=/Users/your-username/Library/Android/sdk

# Firebase config (used by build scripts, NOT checked in)
# - Android: place google-services.json in composeApp/
# - iOS:     place GoogleService-Info.plist in iosApp/iosApp/
# - Web:     fill in webApp/.env.local from webApp/.env.example
